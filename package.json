    "@angular/router": "^18.2.4",
    "@ctrl/ngx-emoji-mart": "^9.2.0",
    "@ng-bootstrap/ng-bootstrap": "^17.0.1",
    "@ngui/scrollable": "^0.9.1",
    "@ngx-translate/core": "^15.0.0",
    "@ngx-translate/http-loader": "^8.0.0",
    "@omnedia/ngx-background-beams": "^1.0.2",

{
  "name": "notado-frontend",
  "version": "1.1.915",
  "license": "MIT",
  "author": "Tomas Marik",
  "angular-cli": {},
  "scripts": {
    "ng": "ng",
    "lib-build": "ng build notado-lib",
    "lib-pack": "cd dist/notado-lib && npm pack",
    "copy-css": "cp -r projects/notado-lib/src/style dist/notado-lib",
    "copy-font": "cp -r projects/notado-lib/src/fonts dist/notado-lib",
    "lib-dist": "npm run lib-build && npm run copy-font && yarn run lib-pack",
    "lib-up": "node ./update-lib-version.js",
    "start": "ng serve",
    "build-prod": "npm version patch && node ./replace.build.js && ng build --configuration production --aot",
    "build": "ng build",
    "build-test": "ng build --aot --configuration test",
    "test": "ng test",
    "pree2e": "webdriver-manager update --standalone false --gecko false",
    "e2e": "protractor",
    "lint": "tslint \"src/**/*.ts\"",
    "form": "node scripts/form-mode.js",
    "formr": "node scripts/form-mode-revert.js"
  },
  "private": true,
  "dependencies": {
    "@alyle/ui": "16.1.0",
